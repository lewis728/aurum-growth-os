// prisma/schema.prisma
// Aurum Growth OS — Canonical Database Schema
// Source of Truth: Master Implementation Guide Section 4.3
// Seven models: CampaignBlueprint, Lead, Appointment, ScheduledReminder, CommandLog, MetaConnection, CalendarConnection

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── CampaignBlueprint ────────────────────────────────────────────────
// Stores the full campaign configuration and orchestration state.
// The five layer interfaces (CreativeLayer, MediaBuyingLayer, DeploymentLayer,
// VoiceLayer, CRMLayer) are stored as Json columns and cast at the service layer.
model CampaignBlueprint {
  id               String   @id @default(cuid())
  tenantId         String
  status           String   // CampaignStatus enum stored as string
  vertical         String   // ServiceVertical enum stored as string
  businessName     String
  targetLocation   String
  dailyBudgetUsd   Float
  clientTier       String   @default("full_service") // starter | full_service — drives per-seat billing
  clientContactName String? // The agency's client contact (for WhatsApp updates)
  clientWhatsApp    String? // E.164 WhatsApp number for monthly summary messages
  creative         Json     // CreativeLayer
  mediaBuying      Json     // MediaBuyingLayer
  deployment       Json     // DeploymentLayer
  voice            Json     // VoiceLayer
  crm              Json     // CRMLayer
  orchestrationLog Json     @default("[]") // OrchestratorEvent[]
  aggregated         Boolean  @default(false)  // Set to true after performanceAggregator runs
  pendingOrgLink     Boolean  @default(false)  // true if saved with userId fallback before orgId propagated
  // Agency onboarding answers (populated during onboarding chat)
  agencyName         String?
  niches             String?
  currentClientCount String?
  currentFulfilment  String?
  primaryGoal        String?
  // Add Client answers (populated during add-client chat)
  businessDescription String?
  monthlyAdBudget    String?
  idealLead          String?
  desiredOutcome     String?
  offerHook          String?
  // Morning briefing — generated by the 6am briefing cron, shown in client sub-account
  lastBriefingText   String?
  lastBriefingAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  leads            Lead[]
  appointments     Appointment[]
  agentActions     AgentAction[]
  agentInstructions AgentInstruction[]
  clientBrief      ClientBrief?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([pendingOrgLink])
}

// ── ClientBrief ──────────────────────────────────────────────────────
// One per client (blueprint). The dedicated account-manager agent reads this
// at the start of every reasoning cycle so it manages the client to brief —
// ideal/bad leads, brand voice, USPs, and the budget/approval guardrails.
model ClientBrief {
  id                     String   @id @default(cuid())
  blueprintId            String   @unique
  tenantId               String
  idealCustomerProfile   String?
  badLeadSignals         String?
  qualificationQuestions String?
  objectionResponses     Json?
  brandTone              String?
  keyUSPs                String?
  competitorNames        String?
  averageClientValue     Float?
  budgetHardLimit        Float?
  approvalThreshold      Float?
  targetCplGbp           Float?    // the CPL/CPA the agent optimises toward
  complianceNotes        String?   // claims/words the agent must NEVER make — governs ads + calls
  websiteSummary         String?   // GPT-distilled summary of the scraped website
  // ── Kai, the nightly learner (Sprint 6) ─────────────────────────────────────
  distilledLearnings     String?   // ≤15 sharp, client-specific facts distilled nightly from outcomes; every role reads these
  learningsUpdatedAt     DateTime? // when Kai last refreshed distilledLearnings
  reportingPreferences   String?
  clientContactName      String?
  clientContactEmail     String?
  clientWhatsApp         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  blueprint              CampaignBlueprint @relation(fields: [blueprintId], references: [id])
  @@index([tenantId])
}

// ── AgencyProfile ────────────────────────────────────────────────────
// One per tenant. Created at the end of the onboarding conversation.
// Stores the agency owner's answers to the 5 onboarding questions.
model AgencyProfile {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  agencyName         String
  niches             String
  currentClientCount String
  currentFulfilment  String
  primaryGoal        String
  // Chief-of-staff (portfolio agent) context + alerting
  slackWebhookUrl          String?
  agencyAverageClientValue Float?
  targetClientsPerMonth    Int?
  chiefOfStaffBrief        String?
  onboardedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([tenantId])
}

// ── Lead ─────────────────────────────────────────────────────────────
// Created when a prospect fills the Meta landing page form.
// automationEngine fires speed-to-lead SMS immediately on creation.
model Lead {
  id              String   @id @default(cuid())
  blueprintId     String?
  tenantId        String
  firstName       String
  lastName        String
  phone           String
  email           String?
  status          String   @default("new") // LeadStatus enum stored as string
  source          String   @default("landing_page") // landing_page | calendly | manual
  retellCallId    String?  // Retell call_id from the speed-to-lead outbound call
  callAttempts    Int      @default(0) // Number of outbound call attempts placed
  leadScore       Int?     // 1-10 intent score computed at webhook receipt
  callAnalysis    Json?    // CallAnalysis from Retell post-call webhook
  formData        Json?    // Raw form fields from landing page
  // ── CRM pipeline (Sprint 3B) ────────────────────────────────────────────────
  pipelineStage   String   @default("new") // new|called|qualified|booked|showed|converted (+ sub: no_answer|no_show|not_interested|retry_queue). Derived from status+appointment; persisted for indexed aggregates.
  convertedAt     DateTime? // set when the agency owner marks the lead converted
  dealValue       Float?    // actual deal value at conversion (overrides est. avg client value)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  blueprint       CampaignBlueprint? @relation(fields: [blueprintId], references: [id])
  appointment     Appointment?
  @@index([blueprintId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, pipelineStage])
  @@unique([tenantId, email]) // For Calendly lead deduplication by email
}

// ── Appointment ──────────────────────────────────────────────────────
// Created atomically with Lead.update({ status: "booked" }) via $transaction.
// Returns 409 if a confirmed appointment already exists for this lead.
model Appointment {
  id              String   @id @default(cuid())
  blueprintId     String?
  leadId          String   @unique
  tenantId        String
  scheduledAt     DateTime
  confirmed       Boolean  @default(false)
  status          String   @default("confirmed") // AppointmentStatus: confirmed | cancelled | attended
  notes           String?
  calendlyEventId String?  @unique // Calendly scheduled event URI for deduplication
  source          String   @default("retell") // retell | calendly | manual
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  blueprint       CampaignBlueprint?  @relation(fields: [blueprintId], references: [id])
  lead            Lead               @relation(fields: [leadId], references: [id])
  reminders       ScheduledReminder[]
  @@index([blueprintId])
  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@index([calendlyEventId])
}

// ── ScheduledReminder ────────────────────────────────────────────────
// Pre-rendered SMS reminders queued at appointment creation time.
// messageBody is fully rendered at queue time — cron worker sends as-is (GR-08).
// @@unique([appointmentId, messageType]) enforces idempotent queuing (GR-07).
model ScheduledReminder {
  id            String    @id @default(cuid())
  appointmentId String
  tenantId      String
  messageType   String    // ReminderMessageType enum stored as string
  messageBody   String    // Fully rendered SMS body — pre-rendered at queue time (GR-08)
  toNumber      String    // E.164 format
  sendAt        DateTime
  sentAt        DateTime?
  attempts      Int       @default(0)
  status        String    @default("pending") // pending | sent | failed
  createdAt     DateTime  @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  @@unique([appointmentId, messageType])
  @@index([status, sendAt])
  @@index([tenantId])
}

// ── MetaConnection ──────────────────────────────────────────────────
// Stores the tenant's Meta OAuth connection.
// One row per tenant (@@unique on tenantId).
// encryptedAccessToken is AES-256-CBC encrypted — NEVER stored as plaintext.
// All Meta API calls must decrypt via metaAuthService.getMetaAccessToken(tenantId).
model MetaConnection {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  encryptedAccessToken  String    @db.Text  // AES-256-CBC encrypted
  adAccountId           String    // e.g. "act_123456789"
  pageId                String    // Facebook Page ID
  pixelId               String    // Meta Pixel ID
  instagramActorId      String?   // Optional Instagram actor ID
  tokenExpiresAt        DateTime  // Long-lived tokens expire after ~60 days
  connectedAt           DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId])
}

// ── CalendarConnection ──────────────────────────────────────────────
// Stores the tenant's calendar OAuth connection (Google Calendar or Calendly).
// One row per tenant (@@unique on tenantId).
// encryptedToken is AES-256-CBC encrypted — NEVER stored as plaintext.
// Provider abstraction: calendarService.ts reads provider and routes accordingly.
enum CalendarProvider {
  GOOGLE
  CALENDLY
}

model CalendarConnection {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  provider       CalendarProvider
  encryptedToken String           @db.Text  // AES-256-CBC encrypted access token
  refreshToken   String?          @db.Text  // Encrypted refresh token (Google only)
  calendarId     String           // Google: calendar ID; Calendly: user URI
  connectedAt    DateTime         @default(now())
  expiresAt      DateTime?        // Null for Calendly (long-lived tokens)
  updatedAt      DateTime         @updatedAt

  @@index([tenantId])
}

// ── VerticalProfile ─────────────────────────────────────────────────
// Living database of niche intelligence. Grows with every new vertical.
// Seeded with 20 profiles at launch; new verticals auto-generated via GPT-4o.
model VerticalProfile {
  id                        String   @id @default(cuid())
  vertical                  String   @unique  // ServiceVertical enum value or GENERAL_[TYPE]
  displayName               String
  systemPromptBase          String   @default("")  // Base system prompt injected into AI chat for this vertical
  avgTransactionValueGbp    Float
  purchaseTimelineDays      Int
  conversionGoalType        String   // 'formbooking' | 'phonecall' | 'walkin'
  cplBenchmarkGbp           Float
  cplBenchmarkUsd           Float
  creativeStyle             String
  audienceNotes             String
  targetingRecommendations  String
  bidStrategyNotes          String
  offerStructure            String
  callScriptNotes           String
  performanceData           Json     @default("{}")
  lastUpdated               DateTime @updatedAt

  @@index([vertical])
}

// ── AgencyBranding ─────────────────────────────────────────────────
// White-label branding configuration for each agency owner.
// Available to ALL authenticated agency owners on active/trialing subscriptions.
model AgencyBranding {
  id                       String    @id @default(cuid())
  tenantId                 String    @unique
  agencyName               String
  logoUrl                  String?
  primaryColour            String    @default("C9A84C")  // hex, no #
  accentColour             String    @default("FFFFFF")
  customDomain             String?   @unique
  supportEmail             String?
  fromName                 String?
  onboardingWelcomeMessage String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([tenantId])
  @@index([customDomain])
}

// ── AgencySubscription ─────────────────────────────────────────────
// Per-seat billing model. One row per tenant.
// Platform access: £97/month base fee.
// Client seats: £500/month per active CampaignBlueprint.
// Seat count managed by addClientSeat() / removeClientSeat() in stripeService.ts.
model AgencySubscription {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  stripeCustomerId      String    @unique
  stripeSubscriptionId  String    @unique
  status                String    // active | trialing | past_due | canceled
  platformPriceId       String
  seatPriceId           String
  currentSeatCount      Int       @default(0)
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([tenantId])
  @@index([stripeCustomerId])
}

// ── SpendFeeRecord ───────────────────────────────────────────────────
// Monthly 5% ad spend management fee.
// Created on the 1st of each month by the spend-fee cron job.
// @@unique([tenantId, periodMonth]) prevents double-charging.
model SpendFeeRecord {
  id              String    @id @default(cuid())
  tenantId        String
  periodMonth     String    // "2026-01" format
  totalSpendGbp   Float
  feeGbp          Float     // 5% of totalSpendGbp
  stripeInvoiceId String?
  status          String    @default("pending") // pending | invoiced | paid
  createdAt       DateTime  @default(now())

  @@unique([tenantId, periodMonth])
  @@index([tenantId])
  @@index([status])
}

// ── CommandLog ───────────────────────────────────────────────────────
// Append-only audit log of every user command processed by intentProcessor.
// logEvent() wraps all writes in try/catch and fails silently (GR-12).
model CommandLog {
  id          String   @id @default(cuid())
  tenantId    String
  rawInput    String   @db.Text
  intentType  String   // ClassifiedIntent type stored as string
  blueprintId String?  // Populated when intent results in a campaign action
  success     Boolean
  errorMsg    String?
  durationMs  Int?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
}
// ── MonthlyReport ────────────────────────────────────────────────────
// Generated on the 1st of each month for every active/trialing agency owner.
// Stores the email-safe HTML and raw metrics payload.
// @@unique([tenantId, month, year]) prevents duplicate generation.
model MonthlyReport {
  id          String    @id @default(cuid())
  tenantId    String
  month       Int       // 1–12
  year        Int
  reportHtml  String    @db.Text // email-safe inline-styled HTML
  reportData  Json      // raw metrics payload used to generate report
  generatedAt DateTime  @default(now())
  emailedAt   DateTime?

  @@unique([tenantId, month, year])
  @@index([tenantId])
}

// ── AgentAction ──────────────────────────────────────────────────────────────
// Append-only log of every autonomous decision the agent makes per blueprint.
model AgentAction {
  id           String             @id @default(cuid())
  tenantId     String
  blueprintId  String?            // null = portfolio-level (chief-of-staff) action, tenant-scoped only
  agentName    String
  actionType   String
  reasoning    String             @db.Text
  outcome      String
  metricBefore Float?
  metricAfter  Float?
  executedAt   DateTime           @default(now())
  blueprint    CampaignBlueprint? @relation(fields: [blueprintId], references: [id])

  @@index([tenantId, blueprintId])
  @@index([executedAt])
  @@index([tenantId, executedAt])
}

// ── AgentInstruction ──────────────────────────────────────────────────────────
// Standing instructions from agency owner — applied in every reasoning cycle.
model AgentInstruction {
  id          String            @id @default(cuid())
  tenantId    String
  blueprintId String
  instruction String            @db.Text
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  blueprint   CampaignBlueprint @relation(fields: [blueprintId], references: [id])

  @@index([tenantId, blueprintId])
}

// ── AIRepresentative ─────────────────────────────────────────────────────────
// One per CampaignBlueprint. Scoped by blueprintId.
// The agency owner configures this for each client campaign.

enum RepresentativePersonality {
  PROFESSIONAL
  WARM
  DIRECT
  CONSULTATIVE
}

model AIRepresentative {
  id                      String                    @id @default(cuid())
  blueprintId             String                    @unique
  tenantId                String
  repName                 String
  personality             RepresentativePersonality @default(PROFESSIONAL)
  customIntroLine         String?
  customObjectionResponses Json                     @default("{}")
  voiceId                 String?
  lastDeployedAt          DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([tenantId])
  @@index([blueprintId])
}

// ── ClientMessage ─────────────────────────────────────────────────────────────
// Inbound/outbound messages between the agency's CLIENT and the Communicator role
// (Sprint 9). direction: inbound (from client) | outbound (agent reply).
// requiresApproval=true holds an agent reply for owner sign-off before sending.
model ClientMessage {
  id               String    @id @default(cuid())
  blueprintId      String
  tenantId         String
  direction        String    // "inbound" | "outbound"
  channel          String    @default("dashboard") // dashboard | whatsapp | sms | email
  intent           String?   // question | instruction | complaint | praise | request
  content          String    @db.Text
  agentResponse    String?   @db.Text // drafted/sent reply text (for inbound rows)
  requiresApproval Boolean   @default(false)
  approvedAt       DateTime?
  sentAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([tenantId])
  @@index([blueprintId])
  @@index([tenantId, requiresApproval])
}
