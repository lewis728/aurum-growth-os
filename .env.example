# ══════════════════════════════════════════════════════════════════════════════
# Aurum Growth OS — Environment Variable Registry
# Source of Truth: Master Implementation Guide Section 3
# ══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Replace every REPLACE_ME value with your real credentials.
# 3. Never commit .env.local to version control.
# 4. Only NEXT_PUBLIC_APP_URL may carry the NEXT_PUBLIC_ prefix (GR-10).
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Required before Stage 02. Run: npx prisma migrate dev --name init
DATABASE_URL="postgresql://USER:REPLACE_ME@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:REPLACE_ME@HOST:PORT/DATABASE"

# ── Authentication (Clerk) ───────────────────────────────────────────────────
# Required before Stage 03.
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_REPLACE_ME"
CLERK_SECRET_KEY="sk_live_REPLACE_ME"

# ── AI (OpenAI) ──────────────────────────────────────────────────────────────
# Required before Stage 07.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-REPLACE_ME"

# ── Voice AI (Retell) ────────────────────────────────────────────────────────
# Required before Stage 05.
# Get from: https://app.retellai.com → Settings → API Keys
RETELL_API_KEY="key_REPLACE_ME"
RETELL_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ── Meta Ads (Graph API v20.0) ───────────────────────────────────────────────
# Required before Stage 05.
# Get from: https://business.facebook.com → Business Settings → System Users
META_ACCESS_TOKEN="EAAxxxx_REPLACE_ME"
META_AD_ACCOUNT_ID="act_REPLACE_ME"
META_PIXEL_ID="REPLACE_ME"
META_FACEBOOK_PAGE_ID="REPLACE_ME"
META_INSTAGRAM_ACTOR_ID="REPLACE_ME"

# ── Creative AI (Higgsfield) ─────────────────────────────────────────────────
# Required before Stage 05.
# Get from: https://app.higgsfield.ai → Settings → API
HIGGSFIELD_API_KEY="hf_REPLACE_ME"
HIGGSFIELD_API_URL="https://api.higgsfield.ai/v1"

# ── SMS (Twilio) ─────────────────────────────────────────────────────────────
# Required before Stage 04.
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID="ACREPLACE_ME"
TWILIO_AUTH_TOKEN="REPLACE_ME"
TWILIO_FROM_NUMBER="+1REPLACE_ME"
# WhatsApp sender (Sprint 10). Twilio WhatsApp number, e.g. "+447..." or the
# sandbox "+14155238886". The "whatsapp:" prefix is added in code. Falls back to
# TWILIO_FROM_NUMBER if unset.
TWILIO_WHATSAPP_FROM="+1REPLACE_ME"

# ── Deployments (Vercel) ─────────────────────────────────────────────────────
# Required before Stage 05.
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN="REPLACE_ME"
VERCEL_TEAM_ID="team_REPLACE_ME"

# ── Payments (Stripe) ────────────────────────────────────────────────────────
# Required before Stage 04.
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_REPLACE_ME"
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# ── Internal ─────────────────────────────────────────────────────────────────
# Required before Stage 08.
# Generate with: openssl rand -base64 32
CRON_SECRET="REPLACE_ME_min_32_chars_random_string"

# ── App URL ──────────────────────────────────────────────────────────────────
# The ONLY permitted NEXT_PUBLIC_ variable (GR-10).
# Set to your Vercel deployment URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
